"3","4"],"Validation":{"Settings":{"ForceResponse":"ON","ForceResponseType":"ON","Type":"CustomValidation","CustomValidation":{"Logic":{"0":{"0":{"QuestionID":"QID1212517618","QuestionIsInLoop":"no","ChoiceLocator":"q:\/\/QID1212517618\/SelectableChoice\/2","Operator":"Selected","QuestionIDFromLocator":"QID1212517618","LeftOperand":"q:\/\/QID1212517618\/SelectableChoice\/2","Type":"Expression","LogicType":"Question","Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"QuestionDesc\">The specification \"Position: In front of\" refers to:<\/span> <span class=\"LeftOpDesc\">B) The agent being in front of a car.<\/span> <span class=\"OpDesc\">Is Selected<\/span> "},"Type":"If"},"Type":"BooleanExpression"},"Message":{"messageID":"MS_6nXUHGVMFeT5Fat","subMessageID":"VE_CUSTOM_VALIDATION_0","libraryID":"UR_81haFOwirdOynSR","description":"Wrong answer"}}}},"Language":[],"NextChoiceId":5,"NextAnswerId":1,"QuestionText_Unsafe":"The specification \"Position: In front of\" refers to:","DataExportTag":"Q12","QuestionID":"QID1212517618"}},{"SurveyID":"SV_9RXvoU2Xl9xbrf0","Element":"SQ","PrimaryAttribute":"QID1212517619","SecondaryAttribute":"Restrictions on the behavior of the agent in the video can also be added. This is done by applyin...","TertiaryAttribute":null,"Payload":{"QuestionText":"<p dir=\"ltr\"><strong>Restrictions on the behavior of the agent in the video can also be added.<\/strong><br \/>\n<br \/>\nThis is done by applying&nbsp;<strong>constraints<\/strong>&nbsp;on the elements of the frames.<br \/>\nFor example:<\/p>\n\n<ul dir=\"ltr\">\n\t<li>The agent stays behind another vehicle.<br \/>\n\t(the&nbsp;<strong>Position<\/strong>&nbsp;element is constrained to <strong>stay constant<\/strong> the same)&nbsp;&nbsp;<\/li>\n\t<li>The agent changes lanes.&nbsp;<br \/>\n\t(the&nbsp;<strong>Lane<\/strong>&nbsp;element is constrained to <strong>change<\/strong> during the video)<\/li>\n\t<li>The agent changes from lane 1 to lane 3.&nbsp;<br \/>\n\t(the&nbsp;<strong>Lane<\/strong>&nbsp;element is constrained to <strong>change into&nbsp;<\/strong>a<strong> specific<\/strong>&nbsp;Lane element)<\/li>\n<\/ul>\n\n<p dir=\"ltr\"><br \/>\nIt might be convenient to think of a question picturistically:&nbsp;<br \/>\n<img height=\"266\" src=\"https:\/\/technioniit.eu.qualtrics.com\/CP\/Graphic.php?IM=IM_9Rcp6inumf7PFgq\" width=\"800\" \/><br \/>\n&nbsp;<\/p>","QuestionType":"MC","Selector":"SAVR","SubSelector":"TX","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Restrictions on the behavior of the agent in the video can also be added. This is done by applyin...","Choices":[],"ChoiceOrder":[],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"Language":[],"NextChoiceId":4,"NextAnswerId":1,"DataVisibility":{"Private":false,"Hidden":false},"QuestionText_Unsafe":"<p dir=\"ltr\"><strong>Restrictions on the behavior of the agent in the video can also be added.<\/strong><br \/>\n<br \/>\nThis is done by applying&nbsp;<strong>constraints<\/strong>&nbsp;on the elements of the frames.<br \/>\nFor example:<\/p>\n\n<ul dir=\"ltr\">\n\t<li>The agent stays behind another vehicle.<br \/>\n\t(the&nbsp;<strong>Position<\/strong>&nbsp;element is constrained to <strong>stay constant<\/strong> the same)&nbsp;&nbsp;<\/li>\n\t<li>The agent changes lanes.&nbsp;<br \/>\n\t(the&nbsp;<strong>Lane<\/strong>&nbsp;element is constrained to <strong>change<\/strong> during the video)<\/li>\n\t<li>The agent changes from lane 1 to lane 3.&nbsp;<br \/>\n\t(the&nbsp;<strong>Lane<\/strong>&nbsp;element is constrained to <strong>change into&nbsp;<\/strong>a<strong> specific<\/strong>&nbsp;Lane element)<\/li>\n<\/ul>\n\n<p dir=\"ltr\"><br \/>\nIt might be convenient to think of a question picturistically:&nbsp;<br \/>\n<img height=\"266\" src=\"https:\/\/technioniit.eu.qualtrics.com\/CP\/Graphic.php?IM=IM_9Rcp6inumf7PFgq\" width=\"800\" \/><br \/>\n&nbsp;<\/p>","DataExportTag":"Q13","QuestionID":"QID1212517619"}},{"SurveyID":"SV_9RXvoU2Xl9xbrf0","Element":"SQ","PrimaryAttribute":"QID1212517620","SecondaryAttribute":"Example of constraint description using dropdowns:","TertiaryAttribute":null,"Payload":{"QuestionText":"Example of constraint description using dropdowns:","DefaultChoices":false,"QuestionType":"DD","Selector":"DL","Configuration":{"QuestionDescriptionOption":"UseText","VariableCount":3},"QuestionDescription":"Example of constraint description using dropdowns:","Choices":{"2":{"Display":"Element 1"},"3":{"Display":"Constraint"},"7":{"Display":"Element 2"}},"ChoiceOrder":["2","3","7"],"Validation":{"Settings":{"ForceResponse":"OFF","Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":9,"NextAnswerId":1,"Answers":{"1":{"Display":"Behind"},"2":{"Display":"Behind ~ Stays constant"},"3":{"Display":"Behind ~ Stays constant ~ -----"},"4":{"Display":"In front of"},"5":{"Display":"In front of ~ Stays constant"},"6":{"Display":"In front of ~ Stays constant ~ -----"},"7":{"Display":"Above"},"8":{"Display":"Above ~ Stays constant"},"9":{"Display":"Above ~ Stays constant ~ -----"},"10":{"Display":"Below"},"11":{"Display":"Below ~ Stays constant"},"12":{"Display":"Below ~ Stays constant ~ -----"},"13":{"Display":"Lane 1"},"14":{"Display":"Lane 1 ~ Stays constant"},"15":{"Display":"Lane 1 ~ Stays constant ~ -----"},"16":{"Display":"Lane 2"},"17":{"Display":"Lane 2 ~ Stays constant"},"18":{"Display":"Lane 2 ~ Stays constant ~ -----"},"19":{"Display":"Lane 3"},"20":{"Display":"Lane 3 ~ Stays constant"},"21":{"Display":"Lane 3 ~ Stays constant ~ -----"},"22":{"Display":"Lane 4"},"23":{"Display":"Lane 4 ~ Stays constant"},"24":{"Display":"Lane 4 ~ Stays constant ~ -----"},"25":{"Display":"Behind ~ Changes"},"26":{"Display":"Behind ~ Changes ~ -----"},"27":{"Display":"In front of ~ Changes"},"28":{"Display":"In front of ~ Changes ~ -----"},"29":{"Display":"Above ~ Changes"},"30":{"Display":"Above ~ Changes ~ -----"},"31":{"Display":"Below ~ Changes"},"32":{"Display":"Below ~ Changes 